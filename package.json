{
  "name": "show-passwd-extension",
  "version": "1.0.2",
  "private": true,
  "description": "Browser extension that adds eye icons to password fields when native toggles are absent.",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "copy:static": "node scripts/copy-static.mjs",
    "dev": "pnpm copy:static && tsup --watch --env.NODE_ENV=development",
    "build": "tsup --env.NODE_ENV=production && pnpm copy:static",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.4.2",
    "@types/chrome": "0.1.22",
    "@types/jest": "29.5.12",
    "@typescript-eslint/eslint-plugin": "8.45.0",
    "@typescript-eslint/parser": "8.45.0",
    "esbuild": "0.25.10",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-import": "2.32.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jsdom": "27.0.0",
    "prettier": "3.2.5",
    "ts-jest": "29.1.3",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "5.4.5",
    "typescript-eslint": "8.45.0"
  }
}
